[gateway]
gateway ansible_host=${gateway_public_ip} ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/alchemyst-key.pem ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'

[inference]
inference ansible_host=${inference_private_ip} ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/alchemyst-key.pem ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ProxyCommand="ssh -W %h:%p -i ~/.ssh/alchemyst-key.pem -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null ubuntu@${gateway_public_ip}"'

[inference:vars]
gateway_ip=${gateway_private_ip}
